generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  passenger
  conductor
  admin
  logistics_user
}

enum TicketStatus {
  active
  completed
  expired
}

enum ParcelStatus {
  booked
  loaded
  in_transit
  arrived
  delivered
}

enum ParcelHealthStatus {
  stable
  temperature_warning
  shock_warning
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  role         UserRole
  city         String
  tickets      Ticket[]
  parcels      Parcel[] @relation("ParcelSender")
  notifications Notification[]
  seatAlerts   SeatAlertSubscription[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Depot {
  id    String @id @default(cuid())
  name  String
  city  String
  buses Bus[]
}

model RouteLineage {
  id        String  @id @default(cuid())
  name      String
  cityChain String[]
  routes    Route[]
}

model Route {
  id                    String   @id @default(cuid())
  code                  String   @unique
  name                  String
  origin                String
  destination           String
  distanceKm            Int
  averageSegmentMinutes Int
  lineageId             String
  lineage               RouteLineage @relation(fields: [lineageId], references: [id])
  stops                 RouteStop[]
  buses                 Bus[]
}

model RouteStop {
  id        String  @id @default(cuid())
  routeId    String
  route      Route   @relation(fields: [routeId], references: [id])
  name      String
  city      String
  order     Int
  latitude  Float
  longitude Float
}

model Bus {
  id            String  @id @default(cuid())
  code          String  @unique
  routeId       String
  route         Route   @relation(fields: [routeId], references: [id])
  depotId       String
  depot         Depot   @relation(fields: [depotId], references: [id])
  conductorId   String
  occupancy     Int
  seatCapacity  Int
  luggageVolume Int
  luggageUsed   Int
  telemetry     BusTelemetry[]
  parcels       Parcel[]
  parcelScans   ParcelScanEvent[]
  boardingEvents BoardingEvent[]
  occupancySnapshots OccupancySnapshot[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BusTelemetry {
  id           String   @id @default(cuid())
  busId         String
  bus           Bus      @relation(fields: [busId], references: [id])
  latitude     Float
  longitude    Float
  speedKmph    Int
  heading      Int
  currentStopId String
  nextStopId    String
  capturedAt   DateTime @default(now())
}

model Ticket {
  id               String   @id @default(cuid())
  passengerId      String
  passenger        User     @relation(fields: [passengerId], references: [id])
  lineageId        String
  originStopId     String
  destinationStopId String
  allowedSegments  Int[]
  fare             Int
  status           TicketStatus
  qrToken          String   @unique
  issuedAt         DateTime @default(now())
  validUntil       DateTime
  boardingEvents   BoardingEvent[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Parcel {
  id              String   @id @default(cuid())
  senderId        String
  sender          User     @relation("ParcelSender", fields: [senderId], references: [id])
  fromCity        String
  destinationCity String
  length          Int
  width           Int
  height          Int
  weightKg        Float
  assignedBusId   String?
  bus             Bus?     @relation(fields: [assignedBusId], references: [id])
  status          ParcelStatus
  qrToken         String   @unique
  eta             DateTime
  healthStatus    ParcelHealthStatus
  scanEvents      ParcelScanEvent[]
  healthUpdates   ParcelContainerHealth[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ParcelScanEvent {
  id        String   @id @default(cuid())
  parcelId  String
  parcel    Parcel   @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  busId     String
  bus       Bus      @relation(fields: [busId], references: [id])
  eventType String   // "loaded" | "unloaded"
  conductor String
  scannedAt DateTime @default(now())
}

model ParcelContainerHealth {
  id            String   @id @default(cuid())
  parcelId      String
  parcel        Parcel   @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  healthStatus  ParcelHealthStatus
  temperatureC  Float?
  impactG       Float?
  recordedAt    DateTime @default(now())
}

model BoardingEvent {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  busId     String
  bus       Bus      @relation(fields: [busId], references: [id])
  boardedAt DateTime @default(now())
}

model SeatAlertSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  routeId   String
  busId     String?
  minSeats  Int
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  notificationType String // "seat_available" | "parcel_status" | "delay" | "alert"
  relatedId String?  // ticket, parcel, or bus ID
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model OccupancySnapshot {
  id        String   @id @default(cuid())
  busId     String
  bus       Bus      @relation(fields: [busId], references: [id], onDelete: Cascade)
  occupiedSeats Int
  totalSeats    Int
  snapshotAt    DateTime @default(now())
}

model RevenueRecord {
  id        String   @id @default(cuid())
  ticketId  String?
  parcelId  String?
  amount    Int       // in cents
  recordType String   // "ticket" | "parcel"
  recordedAt DateTime @default(now())
}

model AnalyticsAggregate {
  id        String   @id @default(cuid())
  date      DateTime // date of aggregation
  totalTicketsSold Int
  totalRevenueTickets Int
  totalParcelsDelivered Int
  totalRevenueParcel Int
  avgOccupancy Float
  peakHour  Int
  createdAt DateTime @default(now())
}
